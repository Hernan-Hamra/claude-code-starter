{
  "_comment": "Drop-in settings.json for claude-code-starter. Adjust paths if you put hooks somewhere else.",
  "permissions": {
    "defaultMode": "ask",
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(format:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(dd of=/dev/*:*)",
      "Bash(curl*|*bash:*)",
      "Bash(curl*|*sh:*)",
      "Bash(wget*|*bash:*)",
      "Bash(wget*|*sh:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_capture.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/bash_gate.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/write_gate.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/tdd_enforcer.py"
          }
        ]
      }
    ]
  }
}
